<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/rl_bg">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/rl_card_bg"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:elevation="2dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rede_label"
                android:textSize="8sp"
                android:textColor="@color/rl_primary"
                android:letterSpacing="0.1"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/app_logo_reab" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/rl_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="." android:textSize="18sp" android:textColor="@color/rl_text_hint"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/app_logo_lita" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/rl_text_secondary"/>
            </LinearLayout>
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
        <LinearLayout
            android:id="@+id/llLanguageSelector"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="8dp" android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_globe" app:tint="@color/rl_primary"/>
            <TextView android:id="@+id/tvLanguageLabel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/lang_pt_br"
                android:textColor="@color/rl_primary" android:textSize="14sp" android:layout_marginStart="4dp"/>
        </LinearLayout>
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_hamburger"
            app:tint="@color/rl_text_secondary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginStart="4dp"
            android:contentDescription="Menu"/>
    </LinearLayout>

    <!-- Sub header -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/rl_sub_header" android:orientation="horizontal"
        android:paddingHorizontal="16dp" android:paddingVertical="10dp" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/home_title" android:textSize="14sp" android:textColor="@color/rl_text_primary"/>
        <Button android:id="@+id/btnLearnMore" style="@style/RL.Button.Text"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="@string/btn_learn_more" android:textSize="12sp"
            android:textColor="@color/rl_text_secondary" android:background="@drawable/bg_btn_gray_light"
            android:paddingHorizontal="12dp" android:paddingVertical="0dp"/>
    </LinearLayout>

    <!-- Content -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/page_padding_h"
            android:paddingTop="@dimen/page_padding_v"
            android:paddingBottom="@dimen/page_padding_v">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/welcome" android:textSize="24sp" android:textStyle="bold"
                android:textColor="@color/rl_text_primary" android:layout_marginBottom="6dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/welcome_subtitle" android:textSize="14sp"
                android:textColor="@color/rl_text_secondary" android:layout_marginBottom="20dp"/>

            <!-- Two cards row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Ouvir Brasil Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardOuvir"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="12dp"
                    app:cardElevation="2dp" app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/rl_card_bg">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:padding="16dp">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/home_logo_height"
                                android:src="@drawable/logo_ouvir_brasil"
                                android:scaleType="fitCenter"
                                android:contentDescription="Ouvir Brasil"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:text="@string/badge_18_plus"
                                android:textColor="@color/rl_white" android:textSize="11sp" android:textStyle="bold"
                                android:background="@drawable/pill_badge_blue"
                                android:paddingHorizontal="8dp" android:paddingVertical="3dp"/>
                        </FrameLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/rl_divider" android:layout_marginVertical="12dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/quick_audio_title" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/rl_text_primary"
                            android:layout_marginBottom="6dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="0dp"
                            android:layout_weight="1"
                            android:text="@string/quick_audio_desc" android:textSize="12sp"
                            android:textColor="@color/rl_text_secondary" android:lineSpacingMultiplier="1.3"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button android:id="@+id/btnPanelOuvir" style="@style/RL.Button.Outlined"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1" android:text="@string/btn_panel_ouvir"
                                android:textSize="12sp" android:textColor="@color/rl_primary"
                                app:strokeColor="@color/rl_primary" android:layout_marginEnd="8dp"/>
                            <Button android:id="@+id/btnStartOuvir" style="@style/RL.Button"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1" android:text="@string/btn_start_test"
                                android:textSize="12sp" android:backgroundTint="@color/rl_primary"
                                android:textColor="@color/rl_white"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- aud.IT Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAudit"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardElevation="2dp" app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/rl_card_bg">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:padding="16dp">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/home_logo_height"
                                android:src="@drawable/logo_audit"
                                android:scaleType="fitCenter"
                                android:contentDescription="aud.IT — Triagem Auditiva Pediátrica"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:text="@string/badge_4_plus"
                                android:textColor="@color/rl_white" android:textSize="11sp" android:textStyle="bold"
                                android:background="@drawable/pill_badge_blue"
                                android:paddingHorizontal="8dp" android:paddingVertical="3dp"/>
                        </FrameLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/rl_divider" android:layout_marginVertical="12dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/pediatric_audio_title" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/rl_text_primary"
                            android:layout_marginBottom="6dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="0dp"
                            android:layout_weight="1"
                            android:text="@string/pediatric_audio_desc" android:textSize="12sp"
                            android:textColor="@color/rl_text_secondary" android:lineSpacingMultiplier="1.3"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button android:id="@+id/btnPanelAudit" style="@style/RL.Button.Outlined"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1" android:text="@string/btn_panel_audit"
                                android:textSize="12sp" android:textColor="@color/rl_primary"
                                app:strokeColor="@color/rl_primary" android:layout_marginEnd="8dp"/>
                            <Button android:id="@+id/btnStartAudit" style="@style/RL.Button"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1" android:text="@string/btn_start_test"
                                android:textSize="12sp" android:backgroundTint="@color/rl_primary"
                                android:textColor="@color/rl_white"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
