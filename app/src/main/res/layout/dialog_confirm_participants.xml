<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/rl_card_bg">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/confirm_participants_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/rl_text_primary"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"/>

    <!-- Participant list card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="1dp"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="@color/rl_card_bg"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Column header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/label_full_name"
                android:textSize="13sp"
                android:textColor="@color/rl_text_secondary"
                android:gravity="center_vertical"
                android:paddingStart="52dp"
                android:paddingEnd="52dp"
                android:background="@color/rl_bg"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/rl_divider"/>

            <!-- Scrollable participant list -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="240dp">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvConfirmList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Buttons stacked full-width -->
    <Button
        android:id="@+id/btnStartNow"
        style="@style/RL.Button"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_start_now"
        android:backgroundTint="@color/rl_primary"
        android:textColor="@color/rl_white"
        android:textSize="16sp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnCancelTest"
        style="@style/RL.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_cancel_test"
        android:textColor="@color/rl_text_secondary"
        android:textSize="16sp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp"
        app:strokeColor="@color/rl_divider"/>
</LinearLayout>
