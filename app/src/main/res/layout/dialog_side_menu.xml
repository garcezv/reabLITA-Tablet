<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_side_menu">

    <!-- Header: "Opções" + close button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/menu_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/rl_text_primary"/>
        <ImageButton
            android:id="@+id/btnCloseMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete_outline"
            android:background="@drawable/bg_btn_gray_light"
            app:tint="@color/rl_text_secondary"
            android:contentDescription="Fechar"/>
    </LinearLayout>

    <!-- User info section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">
        <FrameLayout
            android:layout_width="@dimen/side_menu_avatar_size"
            android:layout_height="@dimen/side_menu_avatar_size"
            android:background="@drawable/bg_avatar">
            <TextView
                android:id="@+id/tvUserInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="FT"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/rl_white"/>
        </FrameLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuário"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/rl_text_primary"/>
            <TextView
                android:id="@+id/tvUserRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_facilitador"
                android:textSize="13sp"
                android:textColor="@color/rl_text_secondary"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/rl_divider"
        android:layout_marginBottom="4dp"/>

    <!-- Active menu items -->
    <LinearLayout
        android:id="@+id/llMenuInstrucoes"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_instrucoes"
            android:textSize="15sp"
            android:textColor="@color/rl_primary"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llMenuChecarRuido"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_checar_ruido"
            android:textSize="15sp"
            android:textColor="@color/rl_primary"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llMenuProtocolo"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_protocolo"
            android:textSize="15sp"
            android:textColor="@color/rl_primary"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llMenuCalibracao"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_calibracao"
            android:textSize="15sp"
            android:textColor="@color/rl_primary"/>
    </LinearLayout>

    <!-- Active items continued -->
    <LinearLayout
        android:id="@+id/llMenuGerenciarParticipantes"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_gerenciar_participantes"
            android:textSize="15sp"
            android:textColor="@color/rl_primary"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llMenuGerenciarFacilitadores"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_gerenciar_facilitadores"
            android:textSize="15sp"
            android:textColor="@color/rl_primary"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/rl_divider"
        android:layout_marginVertical="4dp"/>

    <!-- Editar perfil -->
    <LinearLayout
        android:id="@+id/llMenuEditarPerfil"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_edit_profile"
            app:tint="@color/rl_primary"
            android:layout_marginEnd="12dp"
            android:contentDescription="Editar perfil"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_editar_perfil"
            android:textSize="15sp"
            android:textColor="@color/rl_primary"/>
    </LinearLayout>

    <!-- Sair -->
    <LinearLayout
        android:id="@+id/llMenuSair"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_logout"
            app:tint="@color/rl_text_secondary"
            android:layout_marginEnd="12dp"
            android:contentDescription="Sair"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_sair"
            android:textSize="15sp"
            android:textColor="@color/rl_text_secondary"/>
    </LinearLayout>
</LinearLayout>
