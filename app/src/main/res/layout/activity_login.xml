<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/rl_bg">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/rl_card_bg"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:elevation="2dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rede_label"
                android:textSize="8sp"
                android:textColor="@color/rl_primary"
                android:letterSpacing="0.1"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_logo_reab"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/rl_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="."
                    android:textSize="18sp"
                    android:textColor="@color/rl_text_hint"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_logo_lita"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/rl_text_secondary"/>
            </LinearLayout>
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
        <LinearLayout
            android:id="@+id/llLanguageSelector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_globe"
                app:tint="@color/rl_primary"/>
            <TextView
                android:id="@+id/tvLanguageLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lang_pt_br"
                android:textColor="@color/rl_primary"
                android:textSize="14sp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Sub header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/rl_sub_header"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/login_page_title"
            android:textSize="14sp"
            android:textColor="@color/rl_text_primary"/>
        <Button
            android:id="@+id/btnLearnMore"
            style="@style/RL.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/btn_learn_more"
            android:textSize="12sp"
            android:textColor="@color/rl_text_secondary"
            android:background="@drawable/bg_btn_gray_light"
            android:paddingHorizontal="12dp"
            android:paddingVertical="0dp"/>
    </LinearLayout>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/page_padding_h"
            android:paddingTop="@dimen/page_padding_v"
            android:paddingBottom="@dimen/page_padding_v">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/login_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/rl_text_primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/login_description"
                android:textSize="13sp"
                android:textColor="@color/rl_text_secondary"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp"/>

            <!-- LGPD Banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_banner"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="24dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_info_outline"
                    app:tint="@color/rl_primary"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="1dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/login_lgpd_notice"
                    android:textSize="13sp"
                    android:textColor="@color/rl_info_text"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

            <!-- Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/rl_card_bg">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        style="@style/RL.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_email"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/rl_text_primary"
                            android:textSize="14sp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"
                        style="@style/RL.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_password"
                        android:layout_marginBottom="20dp"
                        app:passwordToggleEnabled="true">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="@color/rl_text_primary"
                            android:textSize="14sp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnAccess"
                        style="@style/RL.Button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/btn_access"
                        android:backgroundTint="@color/rl_primary"
                        android:textColor="@color/rl_white"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnForgotPassword"
                        style="@style/RL.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/btn_forgot_password"
                        android:textColor="@color/rl_text_primary"
                        app:strokeColor="@color/rl_input_border"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnRequestAccess"
                        style="@style/RL.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/btn_request_access"
                        android:textColor="@color/rl_primary"
                        app:strokeColor="@color/rl_primary"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnGovLogin"
                        style="@style/RL.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/btn_gov_login"
                        android:textColor="@color/rl_text_primary"
                        app:strokeColor="@color/rl_input_border"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
