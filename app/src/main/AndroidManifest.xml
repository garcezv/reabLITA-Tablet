<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.audiometry.threshold">

    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Tablet 10" support: portrait only, large and xlarge screens -->
    <supports-screens
        android:smallScreens="true"
        android:normalScreens="true"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:resizeable="true"
        android:anyDensity="true"/>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/ReabLitaTheme">

        <!-- reab.LITA entry point — portrait only -->
        <activity
            android:name=".LoginActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SolicitarAcessoActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize"
            android:exported="false"/>

        <activity
            android:name=".HomeActivity"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize"
            android:exported="false"/>

        <activity
            android:name=".PainelAuditActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize"
            android:exported="false"/>

        <activity
            android:name=".InstrucoesActivity"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize"
            android:exported="false"/>

        <activity
            android:name=".ChecarRuidoActivity"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize"
            android:exported="false"/>

        <activity
            android:name=".CadastroParticipanteActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize"
            android:exported="false"/>

        <!-- Legacy audiometry exam activity (dark theme) — landscape only -->
        <activity
            android:name=".MainActivity"
            android:theme="@style/AppTheme"
            android:screenOrientation="sensorLandscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustPan"
            android:exported="false"/>

    </application>

</manifest>
